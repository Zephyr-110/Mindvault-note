<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.note.tag.mapper.TagMapper">
    <select id="selectByNameAndUserId" resultType="org.example.note.tag.entity.Tag">
        SELECT id, name, user_id
        FROM tag
        WHERE name = #{name} AND user_id = #{userId}
    </select>
    <select id="selectByUserId" resultType="org.example.note.tag.entity.Tag">
        SELECT id, name, user_id
        FROM tag
        WHERE user_id = #{userId}
    </select>
    <delete id="deleteDocumentTagsByTagId">
        DELETE FROM document_tag
        WHERE tag_id = #{tagId}
    </delete>
</mapper>